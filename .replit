modules = ["nodejs-20"]

[agent]
expertMode = true

[workflows]

[[workflows.workflow]]
name = "Agent"
mode = "sequential"
author = 49633054

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"

[[workflows.workflow]]
name = "web view"
mode = "parallel"
author = 49633054

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/grid-bot run dev"

[[workflows.workflow]]
name = "Bulk Projects"
mode = "parallel"
author = 49633054

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "web view"
