modules = ["nodejs-20"]

[agent]
expertMode = true

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "artifacts/grid-bot: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/grid-bot"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/grid-bot run dev"
cwd = "./artifacts/grid-bot"
waitForPort = 24830
router = "path"

[workflows.workflow.tasks.env]
PORT = "24830"
BASE_PATH = "/"

[userenv]

[userenv.shared]
PORT = "8080"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 24830
externalPort = 3000
